#!/bin/bash
set -euo pipefail

umask 077

APP_DIR="${APP_DIR:-$HOME/songbook-oc}"
ENV_FILE="${ENV_FILE:-$APP_DIR/.env}"
BACKUP_DIR="${BACKUP_DIR:-$APP_DIR/backups/db}"
STATE_DIR="${STATE_DIR:-$BACKUP_DIR/.state}"

log() {
  printf '[%s] %s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*"
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    log "Missing required command: $1"
    exit 1
  fi
}

load_environment() {
  if [ ! -f "$ENV_FILE" ]; then
    log "Environment file not found: $ENV_FILE"
    exit 1
  fi

  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a

  if [ -z "${DATABASE_URL:-}" ]; then
    log "DATABASE_URL is not set in $ENV_FILE"
    exit 1
  fi
}

resolve_database_path() {
  case "$DATABASE_URL" in
    file:/*)
      printf '%s\n' "${DATABASE_URL#file:}"
      ;;
    file:./*)
      printf '%s\n' "$APP_DIR/${DATABASE_URL#file:./}"
      ;;
    file:*)
      printf '%s\n' "$APP_DIR/${DATABASE_URL#file:}"
      ;;
    *)
      log "DATABASE_URL must use SQLite file: syntax, got: $DATABASE_URL"
      exit 1
      ;;
  esac
}

main() {
  require_command gzip
  require_command sha256sum
  require_command sqlite3

  load_environment

  local db_path
  db_path="$(resolve_database_path)"

  if [ ! -f "$db_path" ]; then
    log "Database file not found: $db_path"
    exit 1
  fi

  mkdir -p "$BACKUP_DIR" "$STATE_DIR"

  local temp_dir
  temp_dir="$(mktemp -d)"
  trap "rm -rf '$temp_dir'" EXIT

  local snapshot_path
  snapshot_path="$temp_dir/songbook.db"

  # sqlite3 .backup creates a transactionally consistent snapshot without
  # requiring the app service to stop or risking a torn file copy.
  sqlite3 "$db_path" ".backup '$snapshot_path'"

  local snapshot_hash
  snapshot_hash="$(sha256sum "$snapshot_path" | awk '{print $1}')"

  local latest_hash_file
  latest_hash_file="$STATE_DIR/latest.sha256"

  if [ -f "$latest_hash_file" ] && [ "$(cat "$latest_hash_file")" = "$snapshot_hash" ]; then
    log "Snapshot unchanged; no new backup created."
    return 0
  fi

  local timestamp
  timestamp="$(date -u +%Y%m%dT%H%M%SZ)"

  local short_hash
  short_hash="${snapshot_hash:0:12}"

  local archive_name
  archive_name="songbook-${timestamp}-${short_hash}.db.gz"

  local archive_path
  archive_path="$BACKUP_DIR/$archive_name"

  gzip -n -c "$snapshot_path" >"$archive_path"
  sha256sum "$archive_path" >"$archive_path.sha256"

  cat >"$archive_path.meta" <<EOF
created_at_utc=$timestamp
database_path=$db_path
snapshot_sha256=$snapshot_hash
archive_file=$archive_name
EOF

  printf '%s\n' "$snapshot_hash" >"$latest_hash_file"
  ln -sfn "$archive_name" "$STATE_DIR/latest.db.gz"
  ln -sfn "$(basename "$archive_path.sha256")" "$STATE_DIR/latest.db.gz.sha256"
  ln -sfn "$(basename "$archive_path.meta")" "$STATE_DIR/latest.db.gz.meta"

  log "Created backup: $archive_path"
}

main "$@"
