generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & Auth
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  firstName     String?
  lastName      String?
  username      String?   @unique
  // Deprecated: use firstName + lastName instead
  name          String?
  // null when the account was created via OAuth only
  passwordHash  String?
  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  // Shown on /people when set; optional community-facing note (not for credentials).
  publicBio     String?

  ownedSongs                Song[]                @relation("SongOwner")
  ownedSongbooks            Songbook[]            @relation("SongbookOwner")
  collaborations            Collaboration[]
  invitesSent               Invite[]              @relation("InviteSender")
  invite                    Invite?               @relation("InviteUser")
  // InviteCollaborations where this user is the resource owner
  inviteCollaborationsOwned InviteCollaboration[] @relation("InviteCollabOwner")
passwordResetTokens PasswordResetToken[]
  activityLogs ActivityLog[] @relation("ActivityLogActor")
}

enum Role {
  USER
  ADMIN
}

// Invite tokens are created by admins and emailed to prospective users.
// The invited email must be verified before the token can be consumed.
model Invite {
  id              String    @id @default(cuid())
  email           String
  token           String    @unique
  role            Role      @default(USER)
  expiresAt       DateTime
  // set when the invited email address is verified via the verification link
  emailVerifiedAt DateTime?
  // set when the user actually creates their account
  usedAt          DateTime?

  sentById String
  sentBy   User   @relation("InviteSender", fields: [sentById], references: [id])

  // linked once the user signs up
  userId String? @unique
  user   User?   @relation("InviteUser", fields: [userId], references: [id])

  // content to share with the invited user on sign-up
  inviteCollaborations InviteCollaboration[]
  emailDeliveries      EmailDelivery[]
}

// ---------------------------------------------------------------------------
// Songs
// ---------------------------------------------------------------------------

model Song {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isArchived Boolean  @default(false)
  isPublic   Boolean  @default(false)

  ownerId String
  owner   User   @relation("SongOwner", fields: [ownerId], references: [id])

  // set when this song was forked from another song
  forkedFromId         String?
  forkedFrom           Song?        @relation("SongForks", fields: [forkedFromId], references: [id])
  forks                Song[]       @relation("SongForks")
  recommendedVersionId String?
  recommendedVersion   SongVersion? @relation("RecommendedSongVersion", fields: [recommendedVersionId], references: [id], onDelete: SetNull)

  versions       SongVersion[]
  collaborations Collaboration[]
  tags           SongTagOnSong[]
  categories     SongCategoryOnSong[]
}

model SongVersion {
  id        String   @id @default(cuid())
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  title     String
  author    String?
  content   String
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  recommendedForSongs Song[]         @relation("RecommendedSongVersion")
  songbookSongs       SongbookSong[]
}

model SongTag {
  id   String @id @default(cuid())
  name String @unique

  songs SongTagOnSong[]
}

model SongTagOnSong {
  songId String
  tagId  String

  song Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
  tag  SongTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([songId, tagId])
}

model SongCategory {
  id   String @id @default(cuid())
  name String @unique

  songs SongCategoryOnSong[]
}

model SongCategoryOnSong {
  songId     String
  categoryId String

  song     Song         @relation(fields: [songId], references: [id], onDelete: Cascade)
  category SongCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([songId, categoryId])
}

// ---------------------------------------------------------------------------
// Songbooks
// ---------------------------------------------------------------------------

model Songbook {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isArchived Boolean  @default(false)
  isPublic   Boolean  @default(false)

  ownerId String
  owner   User   @relation("SongbookOwner", fields: [ownerId], references: [id])

  // set when this songbook was forked from another songbook
  forkedFromId String?
  forkedFrom   Songbook?  @relation("SongbookForks", fields: [forkedFromId], references: [id])
  forks        Songbook[] @relation("SongbookForks")

  // JSON configuration for PDF output: mode, fontSize, paperSize
  outputSettings String @default("{}")

  versions       SongbookVersion[]
  collaborations Collaboration[]
}

model SongbookVersion {
  id          String   @id @default(cuid())
  songbookId  String
  songbook    Songbook @relation(fields: [songbookId], references: [id], onDelete: Cascade)
  title       String
  description String?
  createdAt   DateTime @default(now())

  pdfPath        String?
  pdfGeneratedAt DateTime?
  pdfLogPath     String?

  songs SongbookSong[]
}

model SongbookSong {
  id                String          @id @default(cuid())
  songbookVersionId String
  songbookVersion   SongbookVersion @relation(fields: [songbookVersionId], references: [id], onDelete: Cascade)
  songVersionId     String
  songVersion       SongVersion     @relation(fields: [songVersionId], references: [id], onDelete: Cascade)
  order             Int
}

// ---------------------------------------------------------------------------
// Collaboration
// ---------------------------------------------------------------------------

// A Collaboration record grants a user edit access to a song or songbook.
// Exactly one of songId / songbookId must be set (enforced at application level).
model Collaboration {
  id   String     @id @default(cuid())
  role CollabRole @default(EDITOR)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  songId String?
  song   Song?   @relation(fields: [songId], references: [id], onDelete: Cascade)

  songbookId String?
  songbook   Songbook? @relation(fields: [songbookId], references: [id], onDelete: Cascade)

  @@unique([userId, songId])
  @@unique([userId, songbookId])
}

enum CollabRole {
  EDITOR
  ADMIN
}

// ---------------------------------------------------------------------------
// Invite Collaborations
// ---------------------------------------------------------------------------

// Specifies content that should be shared with the invited user upon sign-up.
// resourceType = "song" | "songbook"; scope = "all" means every resource owned
// by `owner`. Specific-resource selection is a planned follow-up (see BACKLOG).
model InviteCollaboration {
  id           String     @id @default(cuid())
  role         CollabRole @default(EDITOR)
  // "all" = all songs/songbooks owned by owner at sign-up time
  resourceType String // "song" | "songbook"

  ownerId String
  owner   User   @relation("InviteCollabOwner", fields: [ownerId], references: [id])

  inviteId String
  invite   Invite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Email Delivery
// ---------------------------------------------------------------------------

model EmailDelivery {
  id        String              @id @default(cuid())
  template  String
  toEmail   String
  fromEmail String
  subject   String
  transport String
  status    EmailDeliveryStatus @default(PENDING)

  metadata          String    @default("{}")
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  inviteId String?
  invite   Invite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  passwordResetTokenId String?
  passwordResetToken   PasswordResetToken? @relation(fields: [passwordResetTokenId], references: [id], onDelete: SetNull)
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}

model PasswordResetToken {
  id String @id @default(cuid())
  tokenHash String @unique
  expiresAt DateTime
  usedAt DateTime?
  createdAt DateTime @default(now())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailDeliveries EmailDelivery[]

  @@index([userId, usedAt, expiresAt])
}

// ---------------------------------------------------------------------------
// Activity Log
// ---------------------------------------------------------------------------

model ActivityLog {
  id String @id @default(cuid())
  createdAt DateTime @default(now())

  // Who performed the action
  actorId String
  actor User @relation("ActivityLogActor", fields: [actorId], references: [id], onDelete: Cascade)

  // Type of activity
  action ActivityAction

  // Resource type and ID
  resourceType ResourceType
  resourceId String

  // For fork: the original resource that was forked
  sourceResourceId String?
  sourceResourceType ResourceType?

  // Additional context (JSON)
  metadata String @default("{}")

  @@index([resourceType, resourceId])
  @@index([actorId])
  @@index([createdAt])
}

enum ActivityAction {
  // Song actions
  SONG_CREATED
  SONG_VERSION_CREATED
  SONG_ARCHIVED
  SONG_RESTORED
  SONG_MADE_PUBLIC
  SONG_MADE_PRIVATE
  SONG_RECOMMENDED_VERSION_CHANGED
  SONG_FORKED

  // Songbook actions
  SONGBOOK_CREATED
  SONGBOOK_VERSION_CREATED
  SONGBOOK_ARCHIVED
  SONGBOOK_RESTORED
  SONGBOOK_MADE_PUBLIC
  SONGBOOK_MADE_PRIVATE
  SONGBOOK_FORKED
  SONGBOOK_SONG_ADDED
  SONGBOOK_SONG_REMOVED

  // Collaboration actions
  COLLABORATOR_ADDED
  COLLABORATOR_REMOVED
  OWNERSHIP_TRANSFERRED

  // Invite actions
  INVITE_SENT
  INVITE_ACCEPTED

  // User actions
  USER_JOINED
}

enum ResourceType {
  SONG
  SONGBOOK
  USER
  INVITE
}
